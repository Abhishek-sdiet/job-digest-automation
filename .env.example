# ============================================
# JOB DIGEST AUTOMATION - ENV CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it's in .gitignore

# --- Gmail SMTP ---
GMAIL_USER=________________________________
GMAIL_APP_PASSWORD=_____________________________
# ⚠️  Use Gmail App Password, NOT your regular password.
# Generate at: https://myaccount.google.com/apppasswords

# --- Email Recipient ---
DIGEST_TO_EMAIL=___________________________________

# --- Google Sheets (for backup) ---
GOOGLE_SHEET_ID=your_google_sheet_id_here
# The long ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/[THIS_PART]/edit
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Get from Google Cloud Console → Service Accounts → Keys

# --- LinkedIn (optional, improves results) ---
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# --- Config ---
MAX_JOBS_PER_EMAIL=30
LOOKBACK_HOURS=24
